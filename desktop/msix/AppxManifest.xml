<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX manifest for ChromaVale.

  For the Microsoft Store, replace these with the values from your reserved app
  in Partner Center (App management -> Product identity):
    - Identity Name        -> "Package/Identity/Name"
    - Identity Publisher    -> "Package/Identity/Publisher" (e.g. CN=ABCD1234-...)
    - PublisherDisplayName  -> your publisher display name

  For local self-signed testing (pack.ps1), Publisher must match the test
  certificate subject, which defaults to CN=ChromaVale.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity Name="ChromaVale"
            Publisher="CN=ChromaVale"
            Version="0.1.0.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>ChromaVale</DisplayName>
    <PublisherDisplayName>ChromaVale</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="ChromaVale" Executable="chromavale.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="ChromaVale"
        Description="Screen color control and color-blind correction"
        BackgroundColor="#16161A"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
